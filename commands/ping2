const os   = require('os');
const fs   = require('fs');
const path = require('path');
const { exec } = require('child_process');
const util = require('util');
const execPromise = util.promisify(exec);

const channelInfo = {
    contextInfo: {
        forwardingScore: 1,
        isForwarded: true,
        forwardedNewsletterMessageInfo: {
            newsletterJid: '0029Vb7yILLBadmWeKQso40p@newsletter',
            newsletterName: 'вңЁ Made By KЙӘбҙҚбҙҖЙҙЙӘ Samuel рҹ’Һ',
            serverMessageId: -1
        }
    }
};

function formatUptime(sec) {
    const d = Math.floor(sec / 86400);
    const h = Math.floor((sec % 86400) / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = Math.floor(sec % 60);
    if (d > 0) return `${d}d ${h}h ${m}m`;
    if (h > 0) return `${h}h ${m}m ${s}s`;
    return `${m}m ${s}s`;
}

function fmt(bytes) {
    if (bytes < 1024)             return `${bytes} B`;
    if (bytes < 1024 ** 2)       return `${(bytes / 1024).toFixed(1)} KB`;
    if (bytes < 1024 ** 3)       return `${(bytes / 1024 ** 2).toFixed(1)} MB`;
    return `${(bytes / 1024 ** 3).toFixed(2)} GB`;
}

function getDirSize(dir) {
    let total = 0;
    try {
        for (const f of fs.readdirSync(dir)) {
            try {
                const fp   = path.join(dir, f);
                const stat = fs.statSync(fp);
                total += stat.isDirectory() ? getDirSize(fp) : stat.size;
            } catch (_) {}
        }
    } catch (_) {}
    return total;
}

function bar(pct, len = 10) {
    const filled = Math.round((Math.min(pct, 100) / 100) * len);
    return 'в–Ҳ'.repeat(filled) + 'в–‘'.repeat(len - filled);
}

async function getDisk() {
    try {
        const { stdout } = await execPromise(`df -k ${process.cwd()}`);
        const p = stdout.trim().split('\n')[1].split(/\s+/);
        return {
            total: parseInt(p[1]) * 1024,
            used:  parseInt(p[2]) * 1024,
            free:  parseInt(p[3]) * 1024,
            pct:   p[4]
        };
    } catch (_) { return null; }
}

async function ping2Command(sock, chatId, message) {
    const start = Date.now();
    try {
        const ping = Date.now() - start;

        const mem     = process.memoryUsage();
        const ramFree  = os.freemem();
