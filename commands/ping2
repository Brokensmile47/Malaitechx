                        getDirSize(path.join(process.cwd(), 'temp'));

        let txt = '';
        txt += `в•ӯв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•®\n`;
        txt += `в”ғ  рҹӨ– *MALAI XD вҖ” BOT STATUS*\n`;
        txt += `в•°в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв•Ҝ\n\n`;

        txt += `*вҡЎ PERFORMANCE*\n`;
        txt += `в”ң рҹҸ“ Ping        : *${ping} ms*\n`;
        txt += `в”ң вҸұпёҸ  Bot Uptime  : *${formatUptime(process.uptime())}*\n`;
        txt += `в”” рҹ–ҘпёҸ  Sys Uptime  : *${formatUptime(os.uptime())}*\n\n`;

        txt += `*рҹ’ҫ MEMORY*\n`;
        txt += `в”ң рҹҹў Heap Used   : *${fmt(mem.heapUsed)}*\n`;
        txt += `в”ң рҹ”ө RAM Used    : *${fmt(ramUsed)}*\n`;
        txt += `в”ң в¬ң RAM Total   : *${fmt(ramTotal)}*\n`;
        txt += `в”” рҹ“Ҡ Usage       : [${bar(ramPct)}] *${ramPct}%*\n\n`;

        if (disk) {
            const diskPct = Math.round((disk.used / disk.total) * 100);
            txt += `*рҹ’ҝ STORAGE*\n`;
            txt += `в”ң вң… Free        : *${fmt(disk.free)}*\n`;
            txt += `в”ң рҹ“Ұ Used        : *${fmt(disk.used)}*\n`;
            txt += `в”ң рҹ—„пёҸ  Total       : *${fmt(disk.total)}*\n`;
            txt += `в”” рҹ“Ҡ Usage       : [${bar(diskPct)}] *${disk.pct}*\n\n`;
        }

        txt += `*рҹ“Ғ BOT FILES*\n`;
        txt += `в”ң рҹ”‘ Session     : *${fmt(sesSize)}*\n`;
        txt += `в”” рҹ—‘пёҸ  Temp/Tmp    : *${fmt(tmpSize)}*\n\n`;

        txt += `*рҹ–ҘпёҸ SYSTEM*\n`;
        txt += `в”ң рҹ’» OS          : *${os.type()} ${os.arch()}*\n`;
        txt += `в”ң рҹ§  CPU         : *${cpuModel}*\n`;
        txt += `в”ң вҡҷпёҸ  Cores       : *${cpus.length}*\n`;
        txt += `в”” рҹҢҗ Node.js     : *${process.version}*\n\n`;

        txt += `*рҹӨ– BOT INFO*\n`;
        txt += `в”ң рҹ“ӣ Name        : *Malai XD рҹҰҲ*\n`;
        txt += `в”ң рҹҸ·пёҸ  Version     : *v3.0.7*\n`;
        txt += `в”ң рҹ‘‘ Owner       : *KЙӘбҙҚбҙҖЙҙЙӘ Samuel*\n`;
        txt += `в”” рҹҹў Status      : *Online & Active*`;

        await sock.sendMessage(chatId, { text: txt, ...channelInfo }, { quoted: message });

    } catch (err) {
        console.error('ping2 error:', err);
        await sock.sendMessage(chatId, {
            text: 'вқҢ Failed to fetch bot details.',
            ...channelInfo
        }, { quoted: message });
    }
}

module.exports = ping2Command;
