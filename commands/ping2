        const ramPct   = Math.round((ramUsed / ramTotal) * 100);

        const cpus     = os.cpus();
        const cpuModel = cpus[0]?.model?.trim() || 'Unknown';

        const disk    = await getDisk();
        const sesSize = getDirSize(path.join(process.cwd(), 'session'));
